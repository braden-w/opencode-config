{
	"plugin": ["oh-my-opencode", "opencode-openai-codex-auth"],
	"mcp": {},
	"provider": {
		"openai": {
			"name": "OpenAI",
			"models": {
				"gpt-5.4": {
					"name": "GPT 5.4 (OAuth)",
					"limit": {
						"context": 1048576,
						"output": 128000
					},
					"modalities": {
						"input": ["text", "image"],
						"output": ["text"]
					}
				},
				"gpt-5.3": {
					"name": "GPT 5.3 (OAuth)",
					"limit": {
						"context": 512000,
						"output": 128000
					},
					"modalities": {
						"input": ["text", "image"],
						"output": ["text"]
					}
				}
			},
			"options": {
				"reasoningEffort": "medium",
				"reasoningSummary": "auto",
				"textVerbosity": "medium",
				"include": ["reasoning.encrypted_content"],
				"store": false
			}
		}
	},
	"$schema": "https://opencode.ai/config.json"
}
